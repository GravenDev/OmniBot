{
  "name": "omni-bot",
  "version": "0.1.0",
  "description": "",
  "main": "./dist/index.js",
  "private": true,
  "scripts": {
    "build": "pnpm prisma:generate && tsc",
    "dev": "node ./bootstrap/validate-env-vars.mjs && node --loader ts-node/esm src/index.ts",
    "start": "node ./bootstrap/validate-env-vars.mjs && node ./dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky || true",
    "prisma:consolidate": "node --loader ts-node/esm scripts/consolidate-schema.ts",
    "prisma:generate": "pnpm prisma:consolidate && prisma generate --no-hints",
    "prisma:migrate": "pnpm prisma:consolidate && prisma migrate dev",
    "prisma:studio": "pnpm prisma:consolidate && prisma studio --no-hints"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@10.15.0",
  "type": "module",
  "dependencies": {
    "@prisma/client": "6.14.0",
    "discord.js": "^14.26.4",
    "prisma": "^6.19.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^22.19.19",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.67.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
