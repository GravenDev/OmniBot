{
  "name": "omni-bot",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "GPL-3.0-or-later",
  "author": "",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "pnpm prisma:generate && tsc",
    "dev": "NODE_ENV=development node --env-file=.env ./bootstrap/validate-env-vars.mjs && NODE_ENV=development node --env-file=.env --import tsx src/index.ts",
    "start": "node ./bootstrap/validate-env-vars.mjs && node ./dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "prepare": "lefthook install || true",
    "format": "oxfmt --write && oxlint --fix --fix-suggestions",
    "prisma:consolidate": "tsx scripts/consolidate-schema.ts",
    "prisma:generate": "pnpm prisma:consolidate && prisma generate --no-hints",
    "prisma:migrate": "pnpm prisma:consolidate && prisma migrate dev",
    "prisma:studio": "pnpm prisma:consolidate && prisma studio --no-hints"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "discord.js": "^14.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@types/node": "^24.0.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.12.0",
    "prisma": "^6.19.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.34.2"
}
